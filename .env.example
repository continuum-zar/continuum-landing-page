# Public API base URL used by the browser (must include `/api/v1`).
# Local dev: leave unset to use the Vite proxy (`/api/v1` → backend).
# Production: set to your deployed API origin, e.g.:
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# VITE_API_BASE_URL=

# Optional: Docker / local backend host for the dev proxy (see vite.config.ts).
# VITE_PROXY_TARGET=http://localhost:8001
